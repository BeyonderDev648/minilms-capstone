# Copy to .env for local development.
# Point this at your backend - include the /api prefix.
# Local backend:
VITE_API_URL=http://localhost:5000/api

# When you deploy, set VITE_API_URL on your hosting platform (Vercel/Netlify)
# to your live Railway URL instead, e.g.:
# VITE_API_URL=https://lms-backend-production-f49e.up.railway.app/api
