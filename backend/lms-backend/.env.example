# Copy this file to .env and fill in real values. Never commit .env

# Postgres connection string. For hosted free options use Neon or Supabase,
# e.g. postgres://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=postgres://user:password@localhost:5432/minilms

# Long random string - used to sign JWTs. Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string

# How long a login token stays valid
JWT_EXPIRES_IN=2h

PORT=5000

# Comma-separated list of allowed frontend origins (React, Flutter web build, etc.)
# Example for local dev + deployed frontend:
# CORS_ORIGIN=http://localhost:5173,https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173
